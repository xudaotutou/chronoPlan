# URL Devnet
NEXT_PUBLIC_DEVNET_PROVIDER_URL=http://127.0.0.1:5050

# URL Sepolia (recommended: use Alchemy or Blast for accurate gas estimation)
# Get free API key from: https://www.alchemy.com/ or https://blastapi.io/
# Using public RPC may cause "Resource bounds were not satisfied" errors due to stale gas estimates
# Alchemy Sepolia:
# NEXT_PUBLIC_SEPOLIA_PROVIDER_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/YOUR_API_KEY
# Blast Sepolia (recommended - no API key needed):
NEXT_PUBLIC_SEPOLIA_PROVIDER_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_9
# Public fallback (may have gas estimation issues):
# NEXT_PUBLIC_SEPOLIA_PROVIDER_URL=https://rpc.sepolia.starknet.rs

# WebSocket URLs (optional - for real-time events)
# NEXT_PUBLIC_DEVNET_WS_PROVIDER_URL=ws://127.0.0.1:5050/ws
# NEXT_PUBLIC_SEPOLIA_WS_PROVIDER_URL=wss://your-sepolia-ws-url

# Standard Token Addresses (same on all networks)
NEXT_PUBLIC_STRK_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# Privy Configuration (Server-managed mode)
# Get these from: https://www.privy.io/dashboard
# Requires Pro plan with Starknet Tier 2 enabled
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# ChronoPlan Network
# Options: "sepolia" (default), "mainnet"
NEXT_PUBLIC_CHRONOPLAN_NETWORK=sepolia

# ---------------------------------------------------------------------------
# Contract Addresses are AUTOMATICALLY managed by Scaffold-Stark
# Do NOT add them here - they are generated during deployment
#
# Deployment updates:
#   packages/snfoundry/deployments/{network}_latest.json
#   packages/nextjs/contracts/deployedContracts.ts
# ---------------------------------------------------------------------------
